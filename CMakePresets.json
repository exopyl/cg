{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 25, "patch": 0 },
  "configurePresets": [
    {
      "name": "_base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE":  "Release",
        "ENABLE_OPENNURBS":  "ON",
        "ENABLE_OCCT":       "ON",
        "ENABLE_SINAIA":     "OFF",
        "ENABLE_CGNET_DEMO": "OFF"
      }
    },
    {
      "name": "local-windows",
      "displayName": "Local (Windows, VS 2022)",
      "description": "Dev local: binaires OPENNURBS/OCCT/wx/googletest pris dans C:/home/dev/extern.",
      "inherits": "_base",
      "generator": "Visual Studio 17 2022",
      "architecture": { "value": "x64", "strategy": "set" },
      "cacheVariables": {
        "ENABLE_SINAIA":     "ON",
        "EXTERN_OPENNURBS":  "...",
        "EXTERN_OCCT":       "...",
        "EXTERN_WXWIDGETS":  "...",
        "EXTERN_GOOGLETEST": "..."
      }
    },
    {
      "name": "ci-linux",
      "displayName": "CI (Linux, Ninja)",
      "description": "Workflow GitHub Actions Linux: OpenNURBS depuis cg_binaries dans .deps/, OCCT via apt (find_package).",
      "inherits": "_base",
      "generator": "Ninja",
      "cacheVariables": {
        "EXTERN_OPENNURBS": "${sourceDir}/.deps/cg_binaries/opennurbs-v8.27.26019.16021",
        "ENABLE_POISSON": "ON"
      }
    },
    {
      "name": "maker-wasm",
      "displayName": "maker (WebAssembly, Emscripten)",
      "description": "Module WASM maker : cgmesh via Emscripten. Generateur NMake (nmake fourni par Visual Studio). Necessite EMSDK dans l'environnement, et cmake + nmake sur le PATH. Configurer avec `cmake --preset maker-wasm` (ou `emcmake cmake --preset maker-wasm`).",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "generator": "NMake Makefiles",
      "toolchainFile": "$env{EMSDK}/upstream/emscripten/cmake/Modules/Platform/Emscripten.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE":          "Release",
        "ENABLE_MAKER":              "ON",
        "ENABLE_OPENNURBS":          "OFF",
        "ENABLE_OCCT":               "OFF",
        "ENABLE_ONNX":               "OFF",
        "ENABLE_POISSON":            "OFF",
        "ENABLE_ZLIB":               "OFF",
        "ENABLE_SINAIA":             "OFF",
        "ENABLE_SULINA":             "OFF",
        "ENABLE_CGNET_DEMO":         "OFF",
        "ENABLE_RECONSTRUCTION_CLI": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "local-windows",
      "configurePreset": "local-windows",
      "configuration": "Release"
    },
    {
      "name": "ci-linux",
      "configurePreset": "ci-linux"
    },
    {
      "name": "maker-wasm",
      "configurePreset": "maker-wasm"
    }
  ],
  "testPresets": [
    {
      "name": "ci-linux",
      "configurePreset": "ci-linux",
      "output": { "outputOnFailure": true },
      "execution": { "noTestsAction": "error" }
    }
  ]
}
